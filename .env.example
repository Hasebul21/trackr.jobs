# Local dev uses SQLite. For Vercel + Supabase set this to your Postgres URL
# and change `provider = "postgresql"` in prisma/schema.prisma.
DATABASE_URL="file:./dev.db"

# Shared secret for /api/cron/refresh. Vercel Cron sends this as the
# `Authorization: Bearer <CRON_SECRET>` header — see vercel.json.
CRON_SECRET="change-me"

NEXT_PUBLIC_APP_URL="http://localhost:3000"
