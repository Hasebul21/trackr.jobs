# Postgres connection string. Works with Neon, Supabase, Vercel Postgres,
# Railway, or self-hosted Postgres. Use the pooled / connection-pooler
# URL on serverless (Vercel) — direct connections will exhaust your
# database's connection limit.
#
# Examples:
#   Neon (pooled):     postgresql://user:pwd@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require
#   Supabase (pooled): postgresql://postgres.<ref>:<pwd>@aws-0-<region>.pooler.supabase.com:6543/postgres?sslmode=require
#   Vercel Postgres:   set automatically as POSTGRES_PRISMA_URL — copy it into DATABASE_URL
#   Local Docker:      postgresql://postgres:postgres@localhost:5432/jobstes
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/jobstes"

# Shared secret for /api/cron/refresh. Vercel Cron sends this as the
# `Authorization: Bearer <CRON_SECRET>` header — see vercel.json.
# Generate one with:  openssl rand -hex 32
CRON_SECRET="change-me"

# Public site URL. Used for absolute links / OG metadata.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Optional: set to "1" to also include the bundled mock provider on
# every refresh. Useful in dev when scrapers return zero (most do from
# residential-blocked IPs). Leave unset in production.
# SEED_MOCK="1"
